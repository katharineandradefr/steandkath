# Required. From MongoDB Atlas: Connect → Drivers → copy connection string.
# Replace <password> and use a database name at the end, e.g. ...mongodb.net/myapp
# Windows: se der querySrv ECONNREFUSED, mantenha mongodb+srv — o app usa DNS 8.8.8.8/1.1.1.1.
# Alternativa: use a "Standard connection string" do Atlas (mongodb:// sem srv).
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority"

# Optional. Public site URL (browser / OAuth redirects).
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- SendGrid (e-mails transacionais) ---
# SENDGRID_API_KEY=""
# Remetente verificado no SendGrid (Single Sender ou domínio autenticado).
# SENDGRID_FROM_EMAIL="Nao-responda@grupomedcof.com.br"

# --- OpenAI ---
# OPENAI_API_KEY="sk-..."

# --- Google Gemini (respostas de IA no chat) ---
# Obter em: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=""

# --- Groq (IA do Dr. Cof e respostas do chat) ---
# Obter gratis em: https://console.groq.com/keys
# GROQ_API_KEY=""

# --- NextAuth + Google (login social) ---
# Gere um segredo: openssl rand -base64 32
# NEXTAUTH_SECRET=""
# Em dev use http://localhost:3000 ; em produção, a URL pública do app.
# NEXTAUTH_URL="http://localhost:3000"
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- SQLite (Drizzle + better-sqlite3) ---
# Caminho do arquivo .db. Se omitido, usa ./data/app.db (criado automaticamente).
# SQLITE_DATABASE_PATH="./data/app.db"
