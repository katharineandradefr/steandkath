# Required. From MongoDB Atlas: Connect → Drivers → copy connection string.
# Replace <password> and use a database name at the end, e.g. ...mongodb.net/myapp
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME"

# Optional. Public site URL (only if you need it in the browser later).
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
